    {
      "name": "InboxAccount",
      "docs": [
        "Inbox ring buffer. PDA seeds: [\"inbox\", name_hash]",
        "Zero-copy. INBOX_SIZE = 64 (power of 2 for bytemuck compatibility).",
        "Layout: entries(64×16=1024) + head(1) + count(1) + bump(1) + _pad(5) = 1032 bytes"
      ],
      "serialization": "bytemuck",
      "repr": {
        "kind": "c"
      },
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "entries",
            "type": {
