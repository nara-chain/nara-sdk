                },
                64
              ]
            }
          },
          {
            "name": "head",
            "type": "u8"
          },
          {
            "name": "count",
            "type": "u8"
          },
          {
            "name": "bump",
            "type": "u8"
          },
          {
            "name": "_pad",
            "type": {
              "array": [
                "u8",
                5
              ]
            }
          }
